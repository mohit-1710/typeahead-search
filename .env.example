# --- server ---
PORT=8080
HOST=0.0.0.0

# --- postgres (host port 5433 so it doesn't clash with a native 5432) ---
PG_HOST=localhost
PG_PORT=5433
PG_USER=typeahead
PG_PASSWORD=typeahead
PG_DB=typeahead

# --- distributed cache: comma-separated redis nodes (host:port) ---
CACHE_NODES=localhost:7001,localhost:7002,localhost:7003
CACHE_VNODES=160

# suggestion cache TTLs (seconds) — short TTL is the only invalidation we need
TTL_SUGGEST=45
TTL_TREND=8
TTL_JITTER=0.2

# write-behind buffer (batched writes)
BATCH_SIZE_N=2000
FLUSH_INTERVAL_MS=1000
WAL_KEY=wal:searches

# ranking
TOP_K=10
W_POP=1
W_REC=2
DECAY_HALFLIFE_SEC=1800

# trending leaderboard
TREND_DECAY_INTERVAL_MS=30000
